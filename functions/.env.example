# Copy to functions/.env.pharmasocii and fill SMTP_PASS.
# APP_PUBLIC_URL must be listed under Firebase Auth → Settings → Authorized domains.
# Deploy: firebase deploy --only functions
# Never commit functions/.env — it is gitignored.

APP_PUBLIC_URL=https://pharmasocii.firebaseapp.com
VERIFICATION_CC_EMAIL=simrankaurkanda42@gmail.com,singhamyw@outlook.com
COMMUNITY_EMAIL_CC_ALL=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-gmail@gmail.com

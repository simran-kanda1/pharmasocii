rules_version = '2';

// Deploy: firebase deploy --only storage
// Job description PDFs: partners/{uid}/jobDescriptions/...
// Event agenda PDFs: partners/{uid}/eventAgendas/...
service firebase.storage {
  match /b/{bucket}/o {
    match /partners/{partnerId}/jobDescriptions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == partnerId;
    }
    match /partners/{partnerId}/eventAgendas/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == partnerId;
    }

    // Community post images
    match /community/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /admin/settings/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/adminCollection/$(request.auth.uid));
    }
  }
}

rules_version = '2';

// Deploy: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null 
        && firestore.exists(/databases/(default)/documents/adminCollection/$(request.auth.uid));
    }

    match /partners/{partnerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == partnerId || isAdmin());
    }

    // Community post images
    match /community/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /admin/settings/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
